# =========================
# Local stack ports and urls
# =========================
N8N_PORT=5678
NOCODB_PORT=8080
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
NOCODB_PUBLIC_URL=http://localhost:8080
N8N_TIMEZONE=Europe/Moscow
N8N_LOG_LEVEL=info

# =========================
# Secrets (set strong random values)
# =========================
N8N_ENCRYPTION_KEY=replace_with_32_plus_chars_secret
NOCODB_JWT_SECRET=replace_with_32_plus_chars_secret

# =========================
# Database
# =========================
POSTGRES_USER=zephyr
POSTGRES_PASSWORD=replace_postgres_password
POSTGRES_DB=zephyr_ops

# =========================
# Zephyr / sync contract
# =========================
ZEPHYR_BASE_URL=https://jira.navio.auto
ZEPHYR_PROJECT_ID=10904
ZEPHYR_API_TOKEN=
SYNC_INTERVAL_MIN=15
SYNC_MODE=batch
ENABLE_REALTIME_SYNC=false

# Status IDs used in operator_run_form view for pass_checked / fail_checked columns.
# Change these to match your Zephyr instance Pass and Fail test result status IDs.
# Current workflow contract is Pass=145 and Fail=146.
ZEPHYR_PASS_STATUS_ID=145
ZEPHYR_FAIL_STATUS_ID=146

# Endpoint templates and payload mapping
ZEPHYR_UPDATE_ENDPOINT_TEMPLATE=rest/tests/1.0/testresult/{test_result_id}
ZEPHYR_UPDATE_METHOD=PUT
ZEPHYR_UPDATE_STATUS_ID_FIELD=testResultStatusId
ZEPHYR_UPDATE_COMMENT_FIELD=comment
ZEPHYR_UPDATE_EXTRA_BODY_JSON=

# Read-side defaults for ingest
ZEPHYR_ENDPOINT=rest/tests/1.0/testrun/search
ZEPHYR_FOLDER_SEARCH_ENDPOINT=rest/tests/1.0/folder/search
# If folder/search is empty, try instance-specific tree, e.g. rest/tests/1.0/project/10904/foldertree/testrun
ZEPHYR_FOLDERTREE_ENDPOINT=rest/tests/1.0/foldertree
# One parent folder that contains all date subfolders with cycles: set its folder tree id here (comma-separated for several roots).
ZEPHYR_FOLDER_ROOT_IDS=
# false = every folder under the root(s), including date folders and any parents; true = only leaf folders (use if cycles exist only in deepest date folders).
ZEPHYR_FOLDER_LEAF_ONLY=false
ZEPHYR_FOLDER_NAME_REGEX=
ZEPHYR_FOLDER_PATH_REGEX=
# Use {project_id} and {folder_id} placeholders (filled from ZEPHYR_PROJECT_ID and each folder row).
ZEPHYR_QUERY_TEMPLATE=testRun.projectId IN ({project_id}) AND testRun.folderTreeId IN ({folder_id}) ORDER BY testRun.name ASC
# Requested fields for testrun/search. Keep in sync with your working Zephyr UI request if backend is strict.
ZEPHYR_TESTRUN_FIELDS=id,key,name,folderId,iterationId,projectVersionId,environmentId,userKeys,environmentIds,plannedStartDate,plannedEndDate,executionTime,estimatedTime,testResultStatuses,testCaseCount,issueCount,status(id,name,i18nKey,color),customFieldValues,createdOn,createdBy,updatedOn,updatedBy,owner
# Fetch test results snapshot per test run after test_runs ingest.
ZEPHYR_TESTRESULT_ENDPOINT_TEMPLATE=rest/tests/1.0/testrun/{test_run_id}/testrunitems
ZEPHYR_TESTRESULT_FIELDS=id,index,$lastTestResult
# Per-folder page size for testrun/search (raise if a date folder has many cycles; pagination not yet in n8n).
ZEPHYR_MAX_RESULTS=200
ZEPHYR_START_AT=0
ZEPHYR_ARCHIVED=false

# Grist managed operator form sync
GRIST_API_URL=https://api.getgrist.com/api
GRIST_DOCS_BASE_URL=https://docs.getgrist.com
GRIST_PARENT_WORKSPACE_ID=
GRIST_ZEPHYR_PARENT_FOLDER_ID=
GRIST_DOC_ID=
GRIST_TABLE_ID=Table1
GRIST_API_TOKEN=
GRIST_MAX_RECORDS=500
GRIST_STATUS_LOOKBACK_HOURS=72
# Keep Grist status IDs aligned with ZEPHYR_PASS_STATUS_ID/ZEPHYR_FAIL_STATUS_ID.
GRIST_DONE_STATUS_ID=145
GRIST_NOT_DONE_STATUS_ID=146
