# =========================
# n8n / Postgres
# =========================
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_TIMEZONE=Europe/Moscow
N8N_LOG_LEVEL=info

# =========================
# Secrets
# =========================
N8N_ENCRYPTION_KEY=

# =========================
# Database
# =========================
POSTGRES_USER=zephyr
POSTGRES_PASSWORD=
POSTGRES_DB=zephyr_ops

# =========================
# Zephyr
# =========================
ZEPHYR_BASE_URL=https://jira.example.com
ZEPHYR_PROJECT_ID=
ZEPHYR_API_TOKEN=
ZEPHYR_PASS_STATUS_ID=145
ZEPHYR_FAIL_STATUS_ID=146
ZEPHYR_UPDATE_ENDPOINT_TEMPLATE=rest/tests/1.0/testresult/{test_result_id}
ZEPHYR_UPDATE_METHOD=PUT
ZEPHYR_UPDATE_STATUS_ID_FIELD=testResultStatusId
ZEPHYR_UPDATE_COMMENT_FIELD=comment
ZEPHYR_UPDATE_EXTRA_BODY_JSON=
ZEPHYR_MAX_ATTEMPTS=5
ENABLE_REALTIME_SYNC=false

# =========================
# Read-side defaults
# =========================
ZEPHYR_ENDPOINT=rest/tests/1.0/testrun/search
ZEPHYR_FOLDER_SEARCH_ENDPOINT=rest/tests/1.0/folder/search
ZEPHYR_FOLDERTREE_ENDPOINT=rest/tests/1.0/foldertree
ZEPHYR_FOLDER_ROOT_IDS=
ZEPHYR_FOLDER_LEAF_ONLY=false
ZEPHYR_FOLDER_NAME_REGEX=
ZEPHYR_FOLDER_PATH_REGEX=
ZEPHYR_QUERY_TEMPLATE=testRun.projectId IN ({project_id}) AND testRun.folderTreeId IN ({folder_id}) ORDER BY testRun.name ASC
ZEPHYR_TESTRUN_FIELDS=id,key,name,folderId,iterationId,projectVersionId,environmentId,userKeys,environmentIds,plannedStartDate,plannedEndDate,executionTime,estimatedTime,testResultStatuses,testCaseCount,issueCount,status(id,name,i18nKey,color),customFieldValues,createdOn,createdBy,updatedOn,updatedBy,owner,objective
ZEPHYR_TESTRESULT_ENDPOINT_TEMPLATE=rest/tests/1.0/testrun/{test_run_id}/testrunitems
ZEPHYR_TESTRESULT_FIELDS=id,index,$lastTestResult
ZEPHYR_MAX_RESULTS=200
ZEPHYR_START_AT=0
ZEPHYR_ARCHIVED=false

# =========================
# Tally cloud integration
# =========================
TALLY_API_BASE_URL=https://api.tally.so
TALLY_PUBLIC_BASE_URL=https://tally.so/r
TALLY_API_KEY=
TALLY_WORKSPACE_ID=
TALLY_WEBHOOK_SIGNING_SECRET=
TALLY_AGGREGATOR_FORM_ID=
TALLY_AGGREGATOR_OUTPUT_PATH=docs/tally-aggregator.json
TALLY_LANDING_PAGE_URL=
TALLY_LANDING_PAGE_OUTPUT_PATH=docs/tally-landing-page.html
