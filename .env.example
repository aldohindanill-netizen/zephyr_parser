# Zephyr Parser configuration template
# Copy to ".env" and fill real secret values.

# =========================
# REQUIRED SECRETS
# =========================
ZEPHYR_API_TOKEN=replace_with_real_token
GOOGLE_SERVICE_ACCOUNT_FILE=/abs/path/to/your-service-account.json

# =========================
# ZEPHYR CORE
# =========================
ZEPHYR_BASE_URL=https://jira.navio.auto
ZEPHYR_PROJECT_ID=10904
ZEPHYR_ENDPOINT=rest/tests/1.0/testrun/search
ZEPHYR_FOLDER_ENDPOINT=rest/tests/1.0/foldertree
ZEPHYR_FOLDER_SEARCH_ENDPOINT=rest/tests/1.0/folder/search
ZEPHYR_FOLDERTREE_ENDPOINT=rest/tests/1.0/project/10904/foldertree/testrun
ZEPHYR_FIELDS=id,key,name,folderId,iterationId,projectVersionId,environmentId,userKeys,environmentIds,plannedStartDate,plannedEndDate,executionTime,estimatedTime,testResultStatuses,testCaseCount,issueCount,status(id,name,i18nKey,color),customFieldValues,createdOn,createdBy,updatedOn,updatedBy,owner,objective
ZEPHYR_MAX_RESULTS=40
ZEPHYR_START_AT=0
ZEPHYR_ARCHIVED=false
ZEPHYR_DATE_FIELD=updatedOn
ZEPHYR_STATUS_FIELD=status.name
ZEPHYR_DEBUG_FOLDER_FIELDS=false

# =========================
# DISCOVERY / FILTERS
# =========================
ZEPHYR_DISCOVERY_MODE=tree
ZEPHYR_QUERY_TEMPLATE='testRun.projectId IN (10904) AND testRun.folderTreeId IN ({folder_id}) ORDER BY testRun.name ASC'
ZEPHYR_PROJECT_QUERY='testRun.projectId IN (10904) ORDER BY testRun.name ASC'
ZEPHYR_ROOT_FOLDER_IDS=10545
ZEPHYR_ALLOWED_ROOT_FOLDER_IDS=
ZEPHYR_FOLDER_NAME_REGEX='^2026\.\d{2}\.\d{2}$'
ZEPHYR_FOLDER_NAME_ENDPOINT_TEMPLATE=rest/tests/1.0/folder/{folder_id}
ZEPHYR_FOLDER_PATH_REGEX='Ежедневные тесты полигон ML'
ZEPHYR_TREE_LEAF_ONLY=true
ZEPHYR_TREE_NAME_REGEX='^2026\.\d{2}\.\d{2}$'
ZEPHYR_TREE_ROOT_PATH_REGEX=
ZEPHYR_TREE_AUTOPROBE=false

# Optional custom tree source from HAR (priority source).
ZEPHYR_TREE_SOURCE_ENDPOINT=
ZEPHYR_TREE_SOURCE_METHOD=GET
ZEPHYR_TREE_SOURCE_QUERY_JSON=
ZEPHYR_TREE_SOURCE_BODY_JSON=

# =========================
# REPORT OUTPUTS
# =========================
ZEPHYR_OUTPUT=weekly_zephyr_report.csv
ZEPHYR_PER_FOLDER_DIR=reports/by_folder
ZEPHYR_EXPORT_CYCLES_CASES=true
ZEPHYR_CYCLES_CASES_OUTPUT=reports/cycles_and_cases.csv
ZEPHYR_TESTCASE_ENDPOINT_TEMPLATE=rest/tests/1.0/testrun/{cycle_id}/testcase/search
ZEPHYR_SYNTHETIC_CYCLE_IDS=true
ZEPHYR_EXPORT_CASE_STEPS=true
ZEPHYR_CASE_STEPS_OUTPUT=reports/case_steps.csv
ZEPHYR_EXPORT_DAILY_READABLE=true
ZEPHYR_DAILY_READABLE_DIR=reports/daily_readable
ZEPHYR_DAILY_READABLE_FORMATS=html,wiki

# =========================
# OPTIONAL STEP: CREATE FOLDER FIRST
# =========================
ZEPHYR_CREATE_FOLDER_FIRST=false
ZEPHYR_CREATE_FOLDER_NAME=
ZEPHYR_CREATE_FOLDER_NAME_TEMPLATE=%Y.%m.%d
ZEPHYR_CREATE_FOLDER_PARENT_ID=
ZEPHYR_CREATE_FOLDER_ENDPOINT=rest/tests/1.0/folder
ZEPHYR_CREATE_FOLDER_NAME_FIELD=name
ZEPHYR_CREATE_FOLDER_PROJECT_ID_FIELD=projectId
ZEPHYR_CREATE_FOLDER_PARENT_ID_FIELD=parentId
ZEPHYR_CREATE_FOLDER_BODY_JSON=
ZEPHYR_CREATE_FOLDER_DRY_RUN=false
ZEPHYR_CREATE_FOLDER_USE_AS_ROOT=false

# =========================
# GOOGLE SHEETS PIPELINE
# =========================
# Fixed folder name (optional). If empty, generated from template below.
ZEPHYR_BRANCH_NAME=
ZEPHYR_GSHEET_BRANCH_NAME_TEMPLATE=%Y.%m.%d

# Spreadsheet target.
ZEPHYR_GSHEET_SPREADSHEET_ID=
ZEPHYR_GSHEET_SPREADSHEET_TITLE=Zephyr Daily Execution Sheet
ZEPHYR_GSHEET_CONFIG_SHEET=Config
ZEPHYR_GSHEET_RUN_SHEET=Run

# Optional folder disambiguation in generate mode.
ZEPHYR_GSHEET_FOLDER_PARENT_ID=
ZEPHYR_GSHEET_FOLDER_PATH_REGEX=

# Case enrichment and status mapping.
ZEPHYR_GSHEET_TESTCASE_ENDPOINT_TEMPLATE=rest/tests/1.0/testrun/{cycle_id}/testcase/search
ZEPHYR_GSHEET_SYNTHETIC_CYCLE_IDS=true
ZEPHYR_GSHEET_STATUS_PASS_NAME=Pass
ZEPHYR_GSHEET_STATUS_FAIL_NAME=Fail

# Write-back endpoint tuning.
ZEPHYR_GSHEET_UPDATE_ENDPOINT_TEMPLATE=rest/tests/1.0/testresult/{test_result_id}
ZEPHYR_GSHEET_UPDATE_METHOD=PUT
ZEPHYR_GSHEET_UPDATE_STATUS_ID_FIELD=testResultStatusId
ZEPHYR_GSHEET_UPDATE_COMMENT_FIELD=comment
ZEPHYR_GSHEET_UPDATE_EXTRA_BODY_JSON=

# =========================
# DATES
# =========================
ZEPHYR_FROM_DATE=2026-01-01
ZEPHYR_TO_DATE=2026-12-31

# =========================
# NOCODB + N8N LOCAL STACK
# =========================
SYNC_INTERVAL_MIN=15
SYNC_MODE=batch
ENABLE_REALTIME_SYNC=false
RECONCILE_INTERVAL_HOURS=6

# n8n runtime
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_TIMEZONE=Europe/Moscow
N8N_LOG_LEVEL=info
N8N_ENCRYPTION_KEY=replace_with_32_plus_chars_secret

# NocoDB runtime
NOCODB_PORT=8080
NOCODB_PUBLIC_URL=http://localhost:8080
NOCODB_JWT_SECRET=replace_with_32_plus_chars_secret

# Storage for local stack
POSTGRES_USER=zephyr
POSTGRES_PASSWORD=replace_postgres_password
POSTGRES_DB=zephyr_ops

# Grist managed operator form sync
GRIST_API_URL=https://api.getgrist.com/api
GRIST_DOCS_BASE_URL=https://docs.getgrist.com
GRIST_PARENT_WORKSPACE_ID=
GRIST_ZEPHYR_PARENT_FOLDER_ID=
GRIST_DOC_ID=
GRIST_TABLE_ID=Table1
GRIST_API_TOKEN=
GRIST_MAX_RECORDS=500
GRIST_STATUS_LOOKBACK_HOURS=72
# Keep these aligned with workflow mapping constants:
# Pass=145, Fail=146.
GRIST_DONE_STATUS_ID=145
GRIST_NOT_DONE_STATUS_ID=146

# =========================
# BACKWARD-COMPATIBILITY ALIASES
# =========================
# Used as fallback by launchers; keep synced with ZEPHYR_GSHEET_* values if you use them.
GOOGLE_SPREADSHEET_ID=
GOOGLE_SPREADSHEET_TITLE=Zephyr Daily Execution Sheet
GOOGLE_CONFIG_SHEET=Config
GOOGLE_RUN_SHEET=Run

# Optional fallback aliases for write-back tuning.
ZEPHYR_STATUS_PASS_NAME=Pass
ZEPHYR_STATUS_FAIL_NAME=Fail
ZEPHYR_UPDATE_ENDPOINT_TEMPLATE=rest/tests/1.0/testresult/{test_result_id}
ZEPHYR_UPDATE_METHOD=PUT
ZEPHYR_UPDATE_STATUS_ID_FIELD=testResultStatusId
ZEPHYR_UPDATE_COMMENT_FIELD=comment
ZEPHYR_UPDATE_EXTRA_BODY_JSON=
