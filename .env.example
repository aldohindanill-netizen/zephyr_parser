ZEPHYR_API_TOKEN=replace_with_real_token
ZEPHYR_START_AT=0
ZEPHYR_ARCHIVED=false
ZEPHYR_DATE_FIELD=updatedOn
ZEPHYR_STATUS_FIELD=status.name
ZEPHYR_DEBUG_FOLDER_FIELDS=false
ZEPHYR_BASE_URL=https://jira.navio.auto
ZEPHYR_ENDPOINT=rest/tests/1.0/testrun/search
ZEPHYR_DISCOVERY_MODE=tree
ZEPHYR_FOLDER_SEARCH_ENDPOINT=rest/tests/1.0/folder/search
ZEPHYR_FOLDERTREE_ENDPOINT=rest/tests/1.0/project/10904/foldertree/testrun
ZEPHYR_FOLDER_ENDPOINT=rest/tests/1.0/foldertree
ZEPHYR_TREE_LEAF_ONLY=true
ZEPHYR_TREE_NAME_REGEX='^2026\.\d{2}\.\d{2}$'
ZEPHYR_TREE_ROOT_PATH_REGEX=
ZEPHYR_TREE_AUTOPROBE=false
# Optional: set real tree backend from HAR (priority source).
ZEPHYR_TREE_SOURCE_ENDPOINT=
ZEPHYR_TREE_SOURCE_METHOD=GET
ZEPHYR_TREE_SOURCE_QUERY_JSON=
ZEPHYR_TREE_SOURCE_BODY_JSON=
ZEPHYR_OUTPUT=weekly_zephyr_report.csv
ZEPHYR_PER_FOLDER_DIR=reports/by_folder
ZEPHYR_PROJECT_ID=10904
# Optional root-id filters (leave empty for path+name filtering flow).
ZEPHYR_ROOT_FOLDER_IDS=10545
ZEPHYR_ALLOWED_ROOT_FOLDER_IDS=
ZEPHYR_FOLDER_NAME_REGEX='^2026\.\d{2}\.\d{2}$'
ZEPHYR_FOLDER_NAME_ENDPOINT_TEMPLATE=rest/tests/1.0/folder/{folder_id}
ZEPHYR_TESTCASE_ENDPOINT_TEMPLATE=rest/tests/1.0/testrun/{cycle_id}/testcase/search
ZEPHYR_FOLDER_PATH_REGEX='Ежедневные тесты полигон ML'
ZEPHYR_EXPORT_CYCLES_CASES=true
ZEPHYR_CYCLES_CASES_OUTPUT=reports/cycles_and_cases.csv
ZEPHYR_SYNTHETIC_CYCLE_IDS=true
ZEPHYR_EXPORT_CASE_STEPS=true
ZEPHYR_CASE_STEPS_OUTPUT=reports/case_steps.csv
ZEPHYR_EXPORT_DAILY_READABLE=true
ZEPHYR_DAILY_READABLE_DIR=reports/daily_readable
ZEPHYR_DAILY_READABLE_FORMATS=html,wiki
ZEPHYR_QUERY_TEMPLATE='testRun.projectId IN (10904) AND testRun.folderTreeId IN ({folder_id}) ORDER BY testRun.name ASC'
ZEPHYR_PROJECT_QUERY='testRun.projectId IN (10904) ORDER BY testRun.name ASC'
ZEPHYR_FROM_DATE=2026-01-01
ZEPHYR_TO_DATE=2026-12-31
ZEPHYR_MAX_RESULTS=40

# ---------------------------------------------------------------------------
# Redis worker settings (used by redis_runner.py)
# ---------------------------------------------------------------------------
# Host reported on the Amvera project's "Info" page:
#   amvera-<username>-run-<transliterated-project-name>
REDIS_HOST=amvera-myuser-run-my-redis
REDIS_PORT=6379
# Store as a secret in Amvera ("Variables" → "Create secret"):
REDIS_PASSWORD=replace_with_real_password
REDIS_DB=0

# Queue key: push JSON job messages here with LPUSH / RPUSH
REDIS_JOB_QUEUE=zephyr:jobs
# List key where results are appended after each run
REDIS_RESULT_KEY=zephyr:results
# Pub/Sub channel published to after each run
REDIS_RESULT_CHANNEL=zephyr:done
# How long (seconds) to keep the results list in Redis
REDIS_RESULT_TTL=3600
# Heartbeat key and update interval (seconds)
REDIS_HEARTBEAT_KEY=zephyr:heartbeat
REDIS_HEARTBEAT_INTERVAL=30

# ---------------------------------------------------------------------------
# Optional overrides for the token header / prefix used by upload_result
# (defaults match the main Zephyr token settings)
# ---------------------------------------------------------------------------
ZEPHYR_TOKEN_HEADER=Authorization
ZEPHYR_TOKEN_PREFIX=Bearer
