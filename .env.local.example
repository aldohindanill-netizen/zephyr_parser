# Local debug overrides — copy to ".env.local" (gitignored).
# Used only by: .\run_zephyr_local.ps1  (or run_zephyr.ps1 -UseLocalEnv)
# Task Scheduler / run_zephyr_scheduled.ps1 never load this file.
#
# Secrets (ZEPHYR_API_TOKEN, ZEPHYR_CONFLUENCE_API_TOKEN, etc.) stay in ".env".

# =============================================================================
# Isolation from production pipeline
# =============================================================================
ZEPHYR_RUN_LOCK_FILE=reports_local/.zephyr_weekly_report.lock
ZEPHYR_OUTPUT=reports_local/weekly_zephyr_report.csv
ZEPHYR_PER_FOLDER_DIR=reports_local/by_folder
ZEPHYR_CYCLES_CASES_OUTPUT=reports_local/cycles_and_cases.csv
ZEPHYR_CASE_STEPS_OUTPUT=reports_local/case_steps.csv
ZEPHYR_CYCLE_PROGRESS_OUTPUT=reports_local/cycle_progress.csv
ZEPHYR_WEEKLY_CYCLE_MATRIX_OUTPUT=reports_local/weekly_cycle_matrix.csv
ZEPHYR_DAILY_READABLE_DIR=reports_local/daily_readable
ZEPHYR_WEEKLY_READABLE_DIR=reports_local/weekly_readable
ZEPHYR_WEEKLY_ANALYTICS_DIR=reports_local/weekly_analytics
ZEPHYR_BUILD_LOG_REPORT_DIR=reports_local/build_log_reports
ZEPHYR_BUGS_ROLLUP_DIR=reports_local/bugs_rollup
ZEPHYR_AUDIT_LOG=reports_local/audit/audit.jsonl
ZEPHYR_AUDIT_REASON=local debug

# Faster / lighter local runs
ZEPHYR_REGENERATE_LAST_N_DAYS=2
ZEPHYR_FOLDER_WORKERS=1
ZEPHYR_DETAIL_WORKERS=1

# =============================================================================
# Confluence — sandbox only (fill page ids from your test space)
# =============================================================================
# Set all to false for file-only generation (open HTML under reports_local/).
# Set your sandbox page id (not production ZEPHYR_CONFLUENCE_PARENT_PAGE_ID).
# Parent must live in the same Confluence space as ZEPHYR_CONFLUENCE_SPACE_KEY (or the
# script derives space from the parent page automatically).
ZEPHYR_CONFLUENCE_PUBLISH_DAILY=true
ZEPHYR_CONFLUENCE_PUBLISH_WEEKLY=true
ZEPHYR_CONFLUENCE_PUBLISH_WEEKLY_ANALYTICS=true
ZEPHYR_CONFLUENCE_PUBLISH_BUGS=true
ZEPHYR_CONFLUENCE_PARENT_PAGE_ID=replace_with_sandbox_root_page_id
# ZEPHYR_CONFLUENCE_BUGS_PARENT_PAGE_ID=replace_with_sandbox_bugs_parent_id
ZEPHYR_CONFLUENCE_TITLE_PREFIX=[LOCAL]
# Do not match prod pages by title when publishing under sandbox parent (default with prefix).
# ZEPHYR_CONFLUENCE_SPACE_WIDE_TITLE_LOOKUP=false
